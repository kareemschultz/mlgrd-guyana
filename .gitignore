# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
# Cloudflare local credentials / secrets (API token, ADMIN_SECRET, etc.)
.dev.vars
.dev.vars.*

# throwaway QA / verification screenshots
/_reference/_check_*.png
/_reference/_qa_*.png
/_audit/_*.png
/_audit/charts/.gitkeep

# local simulated-Pages serve
/_serve/

# vercel
.vercel

# Claude Code local tooling / worktrees / preview config
.claude/
.worktrees/

# Sensitive directory data (personal mobiles, emails, internal comments) — the
# FULL D1 seed is generated locally by scripts/import-agencies.py for live DB
# seeding only and must never be committed to the public repo.
/scripts/d1-seed-directory.sql
/scripts/d1-seed-datasets-villages.sql
*Agencies & Administrators*.xlsx

# typescript
*.tsbuildinfo
next-env.d.ts
