# Copy to .env.local and fill in.
MAGICUI_PRO_TOKEN=
NEXT_PUBLIC_FORM_ENDPOINT=
NEXT_PUBLIC_BASE_PATH=

# Helpdesk web app embedded (iframe) on /helpdesk. Defaults to the staging app;
# repoint to the production URL on launch, or set to "" to show "launching soon".
NEXT_PUBLIC_HELPDESK_URL=https://app.mlgrd.staging.castech.dev/

# shadcn studio Pro registry credentials (for `npx shadcn add @ss-blocks/...`).
# Put the real values in .env (git-ignored), NOT here. Find them at:
#   email       -> shadcnstudio.com/account-settings
#   license key -> shadcnstudio.com/billing
SHADCN_STUDIO_EMAIL=
SHADCN_STUDIO_LICENSE_KEY=
